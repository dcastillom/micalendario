{
  "name": "micalendario",
  "version": "0.1.7",
  "private": true,
  "description": "Agenda-calendario de escritorio con Astro, Vue y Electron.",
  "author": "Mi Calendario",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"pnpm dev:web\" \"wait-on tcp:4321 && cross-env DEV_SERVER_URL=http://127.0.0.1:4321 electron .\"",
    "dev:web": "astro dev --host 127.0.0.1 --port 4321",
    "desktop": "electron .",
    "update:municipalities": "node scripts/generate-municipalities.mjs",
    "release:next": "node scripts/release-next.mjs",
    "release:patch": "node scripts/release-next.mjs patch",
    "release:minor": "node scripts/release-next.mjs minor",
    "release:major": "node scripts/release-next.mjs major",
    "build:web": "astro build",
    "build": "pnpm build:web && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --publish never",
    "build:mac": "pnpm build:web && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac dmg --publish never",
    "build:win": "pnpm build:web && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win nsis --publish never",
    "preview": "astro preview --host 127.0.0.1 --port 4321"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.57.4",
    "@astrojs/vue": "latest",
    "astro": "latest",
    "vue": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "concurrently": "latest",
    "cross-env": "latest",
    "electron": "latest",
    "electron-builder": "latest",
    "typescript": "latest",
    "wait-on": "latest",
    "xlsx": "^0.18.5"
  },
  "build": {
    "appId": "com.micalendario.desktop",
    "productName": "Mi Calendario",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg"
      ]
    },
    "win": {
      "target": [
        "nsis"
      ]
    }
  },
  "packageManager": "pnpm@10.25.0"
}
