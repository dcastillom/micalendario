---
import "../styles/global.css";

interface Props {
  title?: string;
}

const { title = "Mi Calendario" } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Agenda-calendario de escritorio para pedidos y entregas." />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
